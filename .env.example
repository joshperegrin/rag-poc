# Copy to .env and adjust. Loaded by common/config.py via python-dotenv.

# Remote Ollama host
OLLAMA_BASE_URL=http://192.168.1.74:1143
OLLAMA_MODEL=                 # chat model for document generation, e.g. llama3.1
OLLAMA_EMBED_MODEL=           # embedding model for LanceDB, e.g. nomic-embed-text

# Generation defaults
TEMPERATURE=0.0
NUM_CTX=8192

# LanceDB
LANCEDB_PATH=data/lancedb

# Retrieval / chunking defaults
TOP_K=5
MIN_SCORE=0.0
CHUNK_MIN_CHARS=300
CHUNK_MAX_CHARS=900
